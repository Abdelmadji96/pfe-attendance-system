# Production VPS API (do not overwrite with local Mac IP)
API_BASE_URL=http://187.77.171.204:4000/api

# ── Enrollment (admin desk Pi / enrollment_rfid_sender.py) ──
DEVICE_ID=pi-admin-enrollment-01
ENROLLMENT_DEVICE_SECRET=2b74f36bb6f19fb429d0e767e4f54271eee744ef1c73601f47a3b4b44e2f0e82

# ── Gate attendance (classroom Pi / gate_attendance.py) ──
GATE_DEVICE_ID=pi-gate-01
VERIFICATION_DEVICE_SECRET=53a789501b190b4f21abb265cb7e15245de90695627a7e8ef9d47d46eebf4909

SCAN_DEBOUNCE_SECONDS=3
REQUEST_TIMEOUT_SECONDS=10

# RC522 SPI — auto-probed at startup (chip version 0x91/0x92). Pi 5 is often bus 0, not 10.
# SPI_BUS=0
# SPI_DEVICE=0

# ── Gate camera / FaceNet ──
CAMERA_INDEX=0
CAMERA_DISPLAY_PREVIEW=true
FACE_DETECTION_METHOD=haar
SIMILARITY_THRESHOLD=0.6
ANTI_SPOOF_ENABLED=true
# ANTI_SPOOF_DURATION_SECONDS=0.3

# ── Buzzer + LEDs (BCM numbers — NOT physical pin numbers) ──
# Green LED + → GPIO below, − → GND. Common kit: green on physical pin 11 = GPIO 17.
FEEDBACK_ENABLED=true
GREEN_LED_GPIO=17
RED_LED_GPIO=27
# Buzzer: BCM 22 = physical pin 15 (NOT physical pin 22 — that is RC522 RST / GPIO 25)
BUZZER_GPIO=22
BUZZER_SHORT_MS=200
BUZZER_LONG_MS=800
LED_HOLD_MS=1500
FEEDBACK_ACTIVE_HIGH=true
# Passive buzzer (STEP 2 wiring): one leg → GPIO, other → GND
BUZZER_PASSIVE=true
FEEDBACK_ACTIVE_HIGH=true
SUCCESS_BEEP_COUNT=1
DENY_BEEP_COUNT=3
DENY_BLINK_COUNT=3
FEEDBACK_PULSE_GAP_MS=250

# ── LCD 1602 I2C (PCF8574 backpack — see README wiring) ──
LCD_ENABLED=true
LCD_I2C_BUS=1
LCD_I2C_ADDRESS=39
# 39 = 0x27 (most common). If blank screen, try 63 (0x3F)
# LCD_I2C_ADDRESS=63
LCD_IDLE_LINE1=Scan RFID card
LCD_IDLE_LINE2=Ready
LCD_SUCCESS_LINE1=Welcome!
LCD_ENROLL_SUCCESS_LINE1=Card scanned
LCD_ENROLL_FAIL_LINE1=Scan failed
LCD_MESSAGE_HOLD_MS=3000
# Pin mapping: standard (default) or type2 if text is garbled
LCD_I2C_MAPPING=standard
# LCD_I2C_MAPPING=type2
