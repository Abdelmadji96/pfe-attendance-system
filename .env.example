# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pfe_attendance?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# API
API_PORT=4000
API_URL=http://localhost:4000
ENROLLMENT_DEVICE_SECRET=change-me-in-production
VERIFICATION_DEVICE_SECRET=change-me-in-production
FACE_EMBED_SERVICE_URL=http://192.168.1.10:5055/embed

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Face verification (FaceNet 512-d on Raspberry Pi gate)
SIMILARITY_THRESHOLD=0.6
EMBEDDING_DIMENSION=512
